<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../UIElementsSchema/UIElements.xsd">
    <Style src="project://database/Assets/HealthBar.uss?fileID=7433441132597879392&amp;guid=31265d7a2bf63094e8c9a2f5a4f62d1b&amp;type=3#NewUSSFile" />
    <ui:VisualElement name="health-bar-container" style="flex-grow: 1; width: 100%; height: 100%; margin-top: 20px; margin-right: 20px; margin-bottom: 20px; margin-left: 20px;">
        <ui:VisualElement name="health-bar" style="flex-grow: 1; width: 200px; height: 20px; background-color: rgba(209, 197, 27, 0); border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; overflow: hidden;">
            <ui:VisualElement name="health-fill" style="flex-grow: 1; width: 100%; height: 100%; background-color: rgba(255, 0, 0, 0); transition-property: width; transition-duration: 0.2s; transition-timing-function: ease-out;" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
